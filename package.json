{
  "name": "focory",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "ultracite check",
    "fix": "ultracite fix",
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "gen-openapi": "pnpm -F api gen-openapi",
    "db:generate": "pnpm -F api db:generate",
    "db:migrate": "pnpm -F api db:migrate",
    "db:studio": "pnpm -F api db:studio"
  },
  "packageManager": "pnpm@10.26.2",
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "ultracite": "7.2.2"
  }
}
